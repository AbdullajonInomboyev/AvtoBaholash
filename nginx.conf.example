# /etc/nginx/sites-available/edulens
server {
    listen 80;
    server_name edulens.uz www.edulens.uz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name edulens.uz www.edulens.uz;

    ssl_certificate     /etc/letsencrypt/live/edulens.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/edulens.uz/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    client_max_body_size 50M;

    location /static/ {
        alias /var/www/edulens/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    location /media/ {
        alias /var/www/edulens/media/;
        expires 7d;
    }

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
